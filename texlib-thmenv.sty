\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{texlib-thmenv}[2026/06/09 v2.0 TeXLib theorem-environment enabler]

% ==============================================================================
% texlib-thmenv.sty — single source of truth for TeXLib theorem environments
% ==============================================================================
%
% Two public entry points, both opt-in (requiring the package declares nothing):
%
%   \TeXLibTheorems[numbering=section|flat, aliases=true|false]{theorem, ...}
%       Defines each named environment ONCE — with its canonical amsthm style,
%       the canonical TeXLib tcolorbox look (from texlib-theorems.sty), the
%       chosen shared-counter numbering, an unnumbered `<name>*` twin, and
%       (optionally) the four-letter aliases. Used by the heavier "boxed"
%       classes (didactic, pset), which opt into the subset they want.
%
%   \TeXLibStarredThms
%       Declares the lighter-weight `thm* / defn* / cor* / ...` family —
%       unnumbered, unboxed amsthm statements for in-text use. Used by the
%       exam-class classes (autoexam, quiz). Kept separate from the boxed
%       catalog: the names (thm*, not theorem*) and the no-box behaviour are
%       deliberately different, and folding them together would clash with the
%       boxed `theorem*` / alias `defn*` a {didactic} document defines.
%
% The catalog below — env name -> {label}{amsthm style}{tcolorbox style}{alias}
% — is the one place the full taxonomy lives. `box=none` means "no tcolorbox"
% (remark stays plain inline). `alias` empty means "no four-letter synonym".
%
% \TeXLibTheorems leans on texlib-theorems.sty for the box styles and loads it
% on demand, so a class that only calls \TeXLibStarredThms never pulls in
% tcolorbox.

\RequirePackage{amsthm}
\RequirePackage{etoolbox}   % \AtBeginEnvironment, for the example \solution hook

% ------------------------------------------------------------------------------
% Alias builder (traditional catcodes: needs raw #/## for the env's optional arg)
% ------------------------------------------------------------------------------
% A four-letter alias cannot be a \let-copy of the real environment: the boxed
% environments are wrapped via \tcolorboxenvironment, whose hooks fire only when
% LaTeX sees \begin{<real>} / \end{<real>}. So each alias is a thin wrapper that
% calls \begin{<real>} ... \end{<real>}, passing the optional [<note>] through.
\newcommand{\texlib@thm@mkalias}[2]{% #1 = alias name, #2 = real env name
	\NewDocumentEnvironment{#1}{o}
		{\IfNoValueTF{##1}{\begin{#2}}{\begin{#2}[##1]}}
		{\end{#2}}%
}

% ------------------------------------------------------------------------------
% Worked-problem inline lead-ins  (\solution  \answer / \ans  \pf)
% ------------------------------------------------------------------------------
% The problem-shaped environments (example, exercise, question, challenge, and
% the exam-class statements exam*/ex*/ques*/prob*) bind a small family of inline
% lead-ins for writing a worked solution / answer / proof in line with the
% statement. ALL ALWAYS VISIBLE: a worked solution is exposition, not a build-
% mode-gated key, so they carry no \ifsolutions guard -- the gated mechanism
% stays the separate {solution}/{partsolution} box. Each is an italic label with
% a \bigskip before and an inline space after (matching didactic's \answer).
%
% Two of the requested names collide with existing constructs and are
% deliberately OMITTED rather than allowed to shadow them inside a worked env:
%   \soln  -- didactic already uses {soln} as its solution-BOX alias;
%   \proof -- amsthm owns the {proof} environment.
% The non-colliding members (\solution, \answer, \ans, \pf) cover the same need,
% and {soln} / {proof} stay fully usable (as a sibling after the statement, or
% nested -- neither token is rebound).
% A lone lead-in stays "Solution." / "Answer." / "Proof."; two or more of the
% SAME kind inside one worked env become "Solution 1." / "Solution 2." ... in
% document order (\answer and \ans share the one "Answer" tally). The per-kind
% total isn't known until the env closes, so it is recorded to the .aux at \end
% and read back next run -- like any cross-reference, the numbering settles on
% the second pass (the builder already runs twice). \texlibworkedid gives each
% env instance a stable, document-order id shared between the write and the read.
\newcounter{texlibworkedid}
\newcounter{texlibrcsol}   % per-env running index, reset at each \begin
\newcounter{texlibrcans}
\newcounter{texlibrcpf}

% \texlib@wc@set{id}{kind}{total} -- replayed from the .aux to publish a count.
\def\texlib@wc@set#1#2#3{\expandafter\gdef\csname texlib@wc@#1@#2\endcsname{#3}}
% \texlib@wc@get{id}{kind} -- the recorded total, or 0 before it is known.
\newcommand{\texlib@wc@get}[2]{%
	\ifcsname texlib@wc@#1@#2\endcsname\csname texlib@wc@#1@#2\endcsname\else0\fi}

% \texlib@worked@leadin{running-index counter}{kind}{Label} -- one italic lead-in,
% numbered only when this env holds more than one of the same kind.
\newcommand{\texlib@worked@leadin}[3]{%
	\stepcounter{#1}%
	\edef\texlib@wc@tot{\texlib@wc@get{\texlib@worked@id}{#2}}%
	\par\bigskip\noindent
	% \relax terminates \ifnum's number scan so the following \space is printed,
	% not absorbed as the optional space that ends a TeX <number>.
	\textit{#3\ifnum\texlib@wc@tot>1\relax\space\arabic{#1}\fi.}\space}

\newcommand{\texlib@inline@solution}{\texlib@worked@leadin{texlibrcsol}{sol}{Solution}}
\newcommand{\texlib@inline@answer}  {\texlib@worked@leadin{texlibrcans}{ans}{Answer}}
\newcommand{\texlib@inline@proof}   {\texlib@worked@leadin{texlibrcpf}{pf}{Proof}}

% Bound inside each worked env via \AtBeginEnvironment, so the redefinitions are
% scoped to that environment's group and revert at \end (the class's standalone
% {solution} box, the global \answer, and amsthm's \proof are untouched outside).
% The running indices are global counters (robust to brace/math groups the
% lead-in may sit in), zeroed here per env; \texlib@worked@write ships the totals.
% Nesting two worked envs that both use lead-ins is not supported (the inner env
% resets the shared running counters) -- vanishingly rare and semantically odd.
\newcommand{\texlib@bind@worked}{%
	\stepcounter{texlibworkedid}%
	\edef\texlib@worked@id{\arabic{texlibworkedid}}%
	\setcounter{texlibrcsol}{0}\setcounter{texlibrcans}{0}\setcounter{texlibrcpf}{0}%
	\let\solution\texlib@inline@solution
	\let\answer\texlib@inline@answer
	\let\ans\texlib@inline@answer
	\let\pf\texlib@inline@proof
}

% Bound via \AtEndEnvironment: record each kind's final tally for this env to the
% .aux (read on the next run). Only kinds actually used are written.
\newcommand{\texlib@worked@write}{%
	\texlib@worked@writeone{sol}{texlibrcsol}%
	\texlib@worked@writeone{ans}{texlibrcans}%
	\texlib@worked@writeone{pf}{texlibrcpf}%
}
\newcommand{\texlib@worked@writeone}[2]{%
	\ifnum\value{#2}>0
		\protected@write\@auxout{}{%
			\string\texlib@wc@set{\texlib@worked@id}{#1}{\arabic{#2}}}%
	\fi}

% ------------------------------------------------------------------------------
% {solution}-box numbering  (per-problem scope)
% ------------------------------------------------------------------------------
% The class-local {solution} BOX (didactic/pset) sits as a sibling AFTER a
% problem statement, so its numbering scope is "the current problem" rather than
% an enclosing group: a lone box stays "Solution.", two or more attached to the
% SAME problem become "Solution 1." / "Solution 2." ..., resetting at the next
% problem. \texlibworkedid IS that problem id -- \texlib@bind@worked already
% bumps it at every problem-shaped worked env (example/exercise/question/
% challenge); \texlibnewproblemscope lets a class mark other problem boundaries
% (pset's {problem}). Because the counter is global and monotonic, boxes sharing
% a problem read one stable id; \texlib@solbox@step detects the id change and
% restarts the running box index. Same two-pass .aux tally as the inline lead-ins
% (kind "box"): the per-problem total settles on the second run.
\newcounter{texlibsolbox}          % running box index within the current problem
\def\texlib@solbox@lastepoch{-1}   % problem id the box index was last reset for
\newcommand{\texlibnewproblemscope}{\stepcounter{texlibworkedid}}

% Call once at the start of a rendered {solution} box: advances the running index
% (resetting it when the problem changed), records the running total to the .aux,
% and leaves the header text in \texlib@solbox@label ("Solution" or "Solution N").
\newcommand{\texlib@solbox@label}{Solution}
\newcommand{\texlib@solbox@step}{%
	\edef\texlib@solbox@epoch{\arabic{texlibworkedid}}%
	\ifx\texlib@solbox@epoch\texlib@solbox@lastepoch\else
		\setcounter{texlibsolbox}{0}%
		\global\let\texlib@solbox@lastepoch\texlib@solbox@epoch
	\fi
	\stepcounter{texlibsolbox}%
	\edef\texlib@solbox@tot{\texlib@wc@get{\texlib@solbox@epoch}{box}}%
	% \relax terminates \ifnum's number scan so the \space survives (see the
	% inline lead-in's matching note).
	\edef\texlib@solbox@label{Solution%
		\ifnum\texlib@solbox@tot>1\relax\space\arabic{texlibsolbox}\fi}%
	\protected@write\@auxout{}{%
		\string\texlib@wc@set{\texlib@solbox@epoch}{box}{\arabic{texlibsolbox}}}%
}

\ExplSyntaxOn

% ------------------------------------------------------------------------------
% Catalog
% ------------------------------------------------------------------------------
\prop_new:N \g__texlib_thm_label_prop
\prop_new:N \g__texlib_thm_style_prop
\prop_new:N \g__texlib_thm_box_prop
\prop_new:N \g__texlib_thm_alias_prop

% \__texlib_thm_entry:nnnnn {env}{label}{amsthm style}{tcolorbox style|none}{alias|}
\cs_new_protected:Npn \__texlib_thm_entry:nnnnn #1#2#3#4#5 {
	\prop_gput:Nnn \g__texlib_thm_label_prop {#1} {#2}
	\prop_gput:Nnn \g__texlib_thm_style_prop {#1} {#3}
	\prop_gput:Nnn \g__texlib_thm_box_prop   {#1} {#4}
	\prop_gput:Nnn \g__texlib_thm_alias_prop {#1} {#5}
}

%                          env           label         style       box                alias
\__texlib_thm_entry:nnnnn {theorem}     {Theorem}     {plain}      {texlibtheorem}     {}
\__texlib_thm_entry:nnnnn {corollary}   {Corollary}   {plain}      {texlibtheorem}     {}
\__texlib_thm_entry:nnnnn {lemma}       {Lemma}       {plain}      {texlibtheorem}     {}
\__texlib_thm_entry:nnnnn {conjecture}  {Conjecture}  {plain}      {texlibtheorem}     {}
\__texlib_thm_entry:nnnnn {proposition} {Proposition} {plain}      {texlibproposition} {}
\__texlib_thm_entry:nnnnn {definition}  {Definition}  {definition} {texlibdefinition}  {defn}
\__texlib_thm_entry:nnnnn {convention}  {Convention}  {definition} {texlibdefinition}  {conv}
\__texlib_thm_entry:nnnnn {procedure}   {Procedure}   {definition} {texlibprocedure}   {}
\__texlib_thm_entry:nnnnn {challenge}   {Challenge}   {definition} {texlibquestion}    {chal}
\__texlib_thm_entry:nnnnn {exercise}    {Exercise}    {definition} {texlibexample}     {exer}
\__texlib_thm_entry:nnnnn {example}     {Example}     {definition} {texlibexample}     {exam}
\__texlib_thm_entry:nnnnn {notation}    {Notation}    {definition} {texlibnote}        {notn}
\__texlib_thm_entry:nnnnn {question}    {Question}    {remark}     {texlibquestion}    {ques}
\__texlib_thm_entry:nnnnn {remark}      {Remark}      {remark}     {none}              {}
\__texlib_thm_entry:nnnnn {recall}      {Recall}      {remark}     {texlibnote}        {}
\__texlib_thm_entry:nnnnn {note}        {Note}        {remark}     {texlibnote}        {}

% ------------------------------------------------------------------------------
% Options
% ------------------------------------------------------------------------------
\bool_new:N \l__texlib_thm_section_bool   % numbering: section (true) vs flat (false)
\bool_new:N \l__texlib_thm_aliases_bool
\bool_new:N \l__texlib_thm_first_bool      % next env declared is the master counter
\tl_new:N   \l__texlib_thm_master_tl       % name of the master counter
\tl_new:N   \l__texlib_thm_label_tl
\tl_new:N   \l__texlib_thm_style_tl
\tl_new:N   \l__texlib_thm_box_tl
\tl_new:N   \l__texlib_thm_alias_tl

\keys_define:nn { texlib/thm } {
	numbering .choice:,
	numbering / section .code:n = { \bool_set_true:N  \l__texlib_thm_section_bool },
	numbering / flat    .code:n = { \bool_set_false:N \l__texlib_thm_section_bool },
	aliases   .bool_set:N = \l__texlib_thm_aliases_bool,
	aliases   .default:n  = { true },
}

% ------------------------------------------------------------------------------
% Per-environment declaration
% ------------------------------------------------------------------------------
% Declares one environment from the catalog: amsthm \newtheorem (master counter
% the first time, sharing it thereafter), its unnumbered `<name>*` twin, and the
% tcolorbox wrap on both (unless box=none). Label/style/box are x-expanded into
% the calls so amsthm/tcolorbox receive literal values — the lookup scratch tls
% are overwritten on the next iteration.
\cs_new_protected:Npn \__texlib_thm_declare:n #1 {
	\prop_get:NnNTF \g__texlib_thm_label_prop {#1} \l__texlib_thm_label_tl {
		\prop_get:NnN \g__texlib_thm_style_prop {#1} \l__texlib_thm_style_tl
		\prop_get:NnN \g__texlib_thm_box_prop   {#1} \l__texlib_thm_box_tl
		\exp_args:NV \theoremstyle \l__texlib_thm_style_tl
		\bool_if:NTF \l__texlib_thm_first_bool {
			\tl_set:Nn \l__texlib_thm_master_tl {#1}
			\bool_set_false:N \l__texlib_thm_first_bool
			\bool_if:NTF \l__texlib_thm_section_bool {
				\use:x { \exp_not:N \newtheorem { \exp_not:n {#1} }
					{ \l__texlib_thm_label_tl } [ section ] }
			}{
				\use:x { \exp_not:N \newtheorem { \exp_not:n {#1} }
					{ \l__texlib_thm_label_tl } }
			}
		}{
			\use:x { \exp_not:N \newtheorem { \exp_not:n {#1} }
				[ \l__texlib_thm_master_tl ] { \l__texlib_thm_label_tl } }
		}
		% Unnumbered twin (same style; no \theoremstyle change in between).
		\use:x { \exp_not:N \newtheorem * { \exp_not:n {#1} * }
			{ \l__texlib_thm_label_tl } }
		\str_if_eq:VnF \l__texlib_thm_box_tl { none } {
			\use:x { \exp_not:N \tcolorboxenvironment { \exp_not:n {#1} }
				{ \l__texlib_thm_box_tl } }
			\use:x { \exp_not:N \tcolorboxenvironment { \exp_not:n {#1} * }
				{ \l__texlib_thm_box_tl } }
		}
		% Problem-shaped envs bind the always-visible inline lead-ins
		% (\solution \answer \ans \pf -- see \texlib@bind@worked). Scoped via
		% \AtBeginEnvironment so the redefinitions revert at \end (the class's
		% standalone {solution} box keeps \solution elsewhere); the unnumbered
		% `*' twin gets the same hook.
		\clist_if_in:nnT { example , exercise , question , challenge } {#1} {
			\AtBeginEnvironment{#1}{\texlib@bind@worked}
			\AtBeginEnvironment{#1*}{\texlib@bind@worked}
			\AtEndEnvironment{#1}{\texlib@worked@write}
			\AtEndEnvironment{#1*}{\texlib@worked@write}
		}
	}{
		\msg_error:nnn { texlib-thmenv } { unknown-env } {#1}
	}
}

% Builds the four-letter alias (and its starred twin) for one environment, if
% the catalog assigns it one.
\cs_new_protected:Npn \__texlib_thm_alias:n #1 {
	\prop_get:NnNT \g__texlib_thm_alias_prop {#1} \l__texlib_thm_alias_tl {
		\tl_if_empty:NF \l__texlib_thm_alias_tl {
			\use:x { \exp_not:N \texlib@thm@mkalias
				{ \l__texlib_thm_alias_tl } { \exp_not:n {#1} } }
			\use:x { \exp_not:N \texlib@thm@mkalias
				{ \l__texlib_thm_alias_tl * } { \exp_not:n {#1} * } }
		}
	}
}

\msg_new:nnn { texlib-thmenv } { unknown-env }
	{ Unknown~theorem~environment~'#1'~requested~in~\token_to_str:N
		\TeXLibTheorems. ~ Add~it~to~the~catalog~in~texlib-thmenv.sty. }

% ------------------------------------------------------------------------------
% Public: \TeXLibTheorems[options]{comma list of env names}
% ------------------------------------------------------------------------------
\NewDocumentCommand \TeXLibTheorems { O{} m } {
	\@ifpackageloaded { texlib-theorems } { } { \RequirePackage { texlib-theorems } }
	\bool_set_true:N  \l__texlib_thm_section_bool   % defaults: numbering=section,
	\bool_set_false:N \l__texlib_thm_aliases_bool   %           aliases=false
	\keys_set:nn { texlib/thm } {#1}
	\bool_set_true:N \l__texlib_thm_first_bool
	\clist_map_function:nN {#2} \__texlib_thm_declare:n
	\bool_if:NT \l__texlib_thm_aliases_bool {
		\clist_map_function:nN {#2} \__texlib_thm_alias:n
	}
	\theoremstyle { plain }   % leave amsthm at a clean baseline for later code
}

\ExplSyntaxOff

% ------------------------------------------------------------------------------
% Public: \TeXLibStarredThms — the lightweight unboxed short-name family
% ------------------------------------------------------------------------------
% Plain amsthm \newtheorem* declarations shared by autoexam and quiz: the
% `thm* / defn* / cor* / ...` statements that ship unnumbered and unboxed, for
% in-text mathematical statements. Distinct from the tcolorbox-decorated boxed
% taxonomy above. autoexam's `ex*` and quiz's `exam*` both name the Example
% environment, so both spellings are exposed for backward compatibility.
\newcommand{\TeXLibStarredThms}{%
	% plain style: bold heading, italic body (the amsthm default)
	\theoremstyle{plain}%
	\newtheorem*{thm*}      {Theorem}%
	\newtheorem*{defn*}     {Definition}%
	\newtheorem*{cor*}      {Corollary}%
	\newtheorem*{prop*}     {Proposition}%
	\newtheorem*{lem*}      {Lemma}%
	\newtheorem*{conj*}     {Conjecture}%
	\newtheorem*{ques*}     {Question}%
	\newtheorem*{prob*}     {Problem}%
	\newtheorem*{exam*}     {Example}%
	\newtheorem*{ex*}       {Example}%    legacy short-name spelling
	\newtheorem*{notn*}     {Notation}%
	% remark style: bold heading, upright body
	\theoremstyle{remark}%
	\newtheorem*{rmk*}        {Remark}%
	\newtheorem*{recall*}     {Recall}%
	\newtheorem*{case*}       {Case}%
	\newtheorem*{desiderata*} {Desiderata}%
	% Worked-statement inline lead-ins on the problem-shaped members
	% (\solution \answer \ans \pf -- see \texlib@bind@worked), matching the boxed
	% taxonomy. Scoped per-environment via \AtBeginEnvironment; reverts at \end.
	\AtBeginEnvironment{exam*}{\texlib@bind@worked}%
	\AtBeginEnvironment{ex*}{\texlib@bind@worked}%
	\AtBeginEnvironment{ques*}{\texlib@bind@worked}%
	\AtBeginEnvironment{prob*}{\texlib@bind@worked}%
	\AtEndEnvironment{exam*}{\texlib@worked@write}%
	\AtEndEnvironment{ex*}{\texlib@worked@write}%
	\AtEndEnvironment{ques*}{\texlib@worked@write}%
	\AtEndEnvironment{prob*}{\texlib@worked@write}%
	% Restore the default style so later class code starts clean.
	\theoremstyle{plain}%
}

\endinput
