# Sublime workspace + project state (per-machine)
*.sublime-workspace
*.sublime-project

# Old / superseded files
course-metadata_old.sty

# LaTeX build artifacts
*.aux
*.log
*.out
*.toc
*.synctex.gz
*.synctex.gz.sum.synctex
*.synctex
*.fls
