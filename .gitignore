# Sublime workspace + project state (per-machine)
*.sublime-workspace
*.sublime-project

# Old / superseded files
course-metadata_old.sty

# Local Claude Code session guide (per-machine; not distributed to coworkers)
/CLAUDE.md

# LaTeX build artifacts
*.aux
*.log
*.out
*.toc
*.synctex.gz
*.synctex.gz.sum.synctex
*.synctex
*.fls
*.fdb_latexmk
*.bbl
*.blg
*.nav
*.snm
*.vrb
*.dvi
*.pdf

# TeXLib schedule class scaffolding (now written to the aux dir, but a
# stale copy may linger from a command-line build that bypassed the
# Sublime builder).
*.schedmap
*_schedule_grid.tex

# autoexam / SyncTeX build scratch (generated next to the source by a
# command-line build that bypassed the Sublime builder's cleanup).
*.key
*.sco
*_autoexam_body_*.tex
*.srcmap
*_synctex.tex
*_synctex_*.tex
_footer_check.png

# Python build artifacts
__pycache__/
*.pyc

# smoke_test.py failure logs + local scratch
.smoke_logs/
/dump.txt
# Underscore-prefixed scratch dirs (_scratch, _custtest, _psettest, ...) are
# local experiments that must never reach the public repo.
_*/
# Retired per-machine Sublime user folder (kept on disk, not tracked).
SublimeUser/

# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini
*~
.#*
