\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{texlib-problembank}[2026/05/26 v1.0 TeXLib shared problem-bank
	machinery (engine loader, randomisation, bank queries, item command).]

%
% Provides the problem-bank LaTeX interface and loads the Lua engine that
% backs it.  Both `autoexam` (randomised, multi-version exams) and `quiz`
% (single-version in-class quizzes) build on the same problem-bank workflow,
% so every macro defined here is identical between the two classes.  Keep
% this file the single source of truth; classes only \RequirePackage it and
% then layer their own \begin{problems} environment, \loadbank, and any
% versioning machinery on top.
%
% Loaded automatically by both classes; not intended for direct \usepackage
% by user documents (the document classes already pull it in).
%
% Macros provided:
%   Variable management . . .  \setvar, \setrng, \calcvar, \get
%   Randomisation . . . . . .  \picklist, \picklistr, \pickrange, \pickranger
%   Retrieval . . . . . . . .  \getlist, \geti, \foreachpick
%   Bank: define problems . .  \begin{problem} environment
%   Bank: retrieve problems .  \getproblem (= \useproblem, \reqproblem)
%   Problems environment . .   \begin{problems} (shared; class page policy via
%                              \problems@begin@hook / \problems@end@hook), \ppart,
%                              \@problem@item (the \problem item command, which
%                              {problems} swaps in for \problem in its body)
%   Standalone import . . . .  \importproblem
%   Hooks (overridable) . . .  \workbox, \autoexam@problem@sep,
%                              \problems@begin@hook, \problems@end@hook
%
% \loadbank (below) is shared: it calls pbank_set_bankfile() so the SyncTeX
% bank-file redirect is active for BOTH single- and multi-version builds,
% landing inverse search in the bank source.  (The multi-version loop used to
% suppress the redirect to avoid an \@@input-stack overflow; the
% texlib_synctex.lua helper pops each input at EOF, so that no longer applies.)
%
% Not provided (kept per-class because the semantics differ):
%   Versioning, scorepage, etc. autoexam-only.  The {problems} environment is
%   now shared (see "Problems environment" below); classes inject their page
%   policy via \problems@begin@hook / \problems@end@hook rather than redefining
%   the environment.

\RequirePackage{xparse}
\RequirePackage{environ}  % \Collect@Body for the {problem} environment

% Locates problem_engine.lua and its texlib_synctex.lua dependency across
% three possible layouts:
%   (1) installed in a TEXMF tree              → kpse with the "lua" format
%   (2) sitting next to texlib-problembank.sty → current canonical layout
%   (3) sitting in the cwd                     → standalone test layout
%
% texlib_synctex.lua MUST load before problem_engine.lua: the engine's
% bank-file SyncTeX redirect path calls texlib_synctex_stage at typeset
% time, so the helper must already be defined.
%
% The .sty file is the anchor (rather than the calling .cls) because both
% autoexam.cls and quiz.cls now reach the engine through this package; the
% engine and the .sty travel together at the TeXLib root.
%
% Engine bridge. The bank macros below reach Lua through \pbank@lua. Under
% LuaLaTeX that is simply \directlua, and we load the engine now. Under any
% other engine \directlua does not exist, so we skip the load and point
% \pbank@lua at a clear error instead: a document that merely *loads* this
% package (e.g. didactic.cls auto-loads it so lecture notes can optionally
% \getproblem) still compiles under pdflatex; only an actual bank command
% (\getproblem, \setvar, ...) raises the error. We intentionally do NOT shadow
% the \directlua primitive itself, because other packages probe
% \ifdefined\directlua to detect LuaTeX.
\ifdefined\directlua
	% NOTE: no Lua `--` line comments inside this \directlua block. TeX collapses
	% the newlines into spaces before Lua sees the chunk, so a `--` comment would
	% swallow the rest of the code. Keep explanations in TeX `%` comments above.
	\directlua{
		local function load_engine(name)
			local path = kpse.find_file(name, "lua")
			if path and lfs.attributes(path) then dofile(path) return end
			local sty_path = kpse.find_file("texlib-problembank.sty")
			local base_dir = sty_path and sty_path:match("(.*[/\\])") or ""
			path = base_dir .. name
			if lfs.attributes(path) then dofile(path) return end
			dofile(name)
		end
		load_engine("texlib_synctex.lua")
		load_engine("problem_engine.lua")
	}%
	% The engine no longer pollutes the global Lua namespace: it publishes itself
	% as the single global table `texlib`. Prepending `local _ENV = texlib` lets
	% every bank macro below keep calling bare engine names (set_var, get_problem,
	% vars[...], ...) -- those resolve inside `texlib`, while tex/math/etc. fall
	% through to _G via texlib's metatable. (Must come AFTER the engine load
	% above, which runs as raw \directlua because `texlib` doesn't exist yet.)
	\newcommand{\pbank@lua}[1]{\directlua{local _ENV = texlib;#1}}%
\else
	\newcommand{\pbank@lua}[1]{%
		\PackageError{texlib-problembank}%
			{Problem-bank features require LuaLaTeX}%
			{A texlib-problembank command such as \string\getproblem\space or
			 \string\setvar\space drives a Lua engine through \string\directlua,
			 which only exists under LuaLaTeX. Compile this document with
			 lualatex (or remove the problem-bank usage).}%
	}%
\fi

% \setvar{name}{value}  — store a named value
\newcommand{\setvar}[2]{\pbank@lua{set_var('#1', #2)}}

% \setrng{name}{min}{max}  — store a single random integer in [min, max]
\newcommand{\setrng}[3]{\pbank@lua{set_rng('#1', #2, #3)}}

% \calcvar{name}{lua-expr}  — compute an expression using stored vars
\newcommand{\calcvar}[2]{\pbank@lua{calc_var('#1', '#2')}}

% \get{name}  — retrieve and typeset a stored value
\newcommand{\get}[1]{\pbank@lua{get_var('#1')}}

% \picklist{name}{n}{a, b, c, ...}  — pick n items WITHOUT replacement
% NOTE: list items must not contain commas themselves.
\NewDocumentCommand{\picklist}{m m m}{%
	\pbank@lua{pick_from_list('\luaescapestring{#1}', #2, '\luaescapestring{#3}')}%
}

% \picklistr{name}{n}{a, b, c, ...}  — pick n items WITH replacement
\NewDocumentCommand{\picklistr}{m m m}{%
	\pbank@lua{pick_from_list_r('\luaescapestring{#1}', #2, '\luaescapestring{#3}')}%
}

% \pickrange{name}{n}{min}{max}  — pick n distinct integers from [min, max]
\NewDocumentCommand{\pickrange}{m m m m}{%
	\pbank@lua{pick_from_range('\luaescapestring{#1}', #2, #3, #4)}%
}

% \pickranger{name}{n}{min}{max}  — pick n integers from [min, max] with replacement
\NewDocumentCommand{\pickranger}{m m m m}{%
	\pbank@lua{pick_from_range_r('\luaescapestring{#1}', #2, #3, #4)}%
}

% \getlist{name}  — typeset all picked values, comma-separated
\NewDocumentCommand{\getlist}{m}{%
	\pbank@lua{get_list('\luaescapestring{#1}')}%
}

% \geti{name}{i}  — typeset the i-th picked value (1-indexed)
\NewDocumentCommand{\geti}{m m}{%
	\pbank@lua{get_var('\luaescapestring{#1}_' .. #2)}%
}

% \foreachpick[sep]{name}{code}  — iterate over picked values;
%   \currentpick is set to each value before {code} is executed.
%   Optional [sep] is inserted between items (default: comma-space).
\NewDocumentCommand{\foreachpick}{O{,\space} m +m}{%
	\pbank@lua{
		local count = tonumber(tostring(vars['\luaescapestring{#2}_count'])) or 0
		for i = 1, count do
			local v = vars['\luaescapestring{#2}_' .. i]
			if v ~= nil then
				tex.sprint('\\def\\currentpick{' .. tostring(v) .. '}')
				tex.sprint('\luaescapestring{\unexpanded{#3}}')
				if i < count then
					tex.sprint('\luaescapestring{\unexpanded{#1}}')
				end
			end
		end
	}%
}

% \begin{problem}{id}[key=val, key=val, ...]
%   Define a problem in the bank.  Produces no output at definition time.
%   Everything before the first \solution token in the body is the problem
%   content; everything after is the solution.  Void setup commands
%   (\setrng, \calcvar, etc.) may appear anywhere in the body.
%
%   Implementation notes:
%     - \Collect@Body (from environ) intercepts the body without opening a
%       nested environment, avoiding LaTeX's env-stack mismatch error.
%     - \unexpanded{#1} prevents expansion of \solution and setup commands
%       when the body is passed to \luaescapestring for Lua storage.
%     - define_problem_from_env() splits the resulting string on \solution.

% Internal callback: receives the full collected body as #1.
\long\def\@problem@collect@done#1{%
	\pbank@lua{define_problem_from_env(
		'\luaescapestring{\@problem@id}',
		'\luaescapestring{\@problem@meta}',
		'\luaescapestring{\unexpanded{#1}}'
	)}%
}

% Scan the optional [meta] argument then start body collection.
\def\@problem@scan{%
	\@ifnextchar[%
		{\@problem@getmeta}%
		{\def\@problem@meta{}\Collect@Body\@problem@collect@done}%
}
\def\@problem@getmeta[#1]{%
	\def\@problem@meta{#1}%
	\Collect@Body\@problem@collect@done
}

% Public environment: \begin{problem}{id}[meta] ... \end{problem}
%
% Misuse guard: `\problem` names two different things -- this DEFINITION
% environment everywhere, and (inside \begin{problems}, where it is \let to the
% retrieval item) a RETRIEVAL command. A user who writes a bare \problem{filter}
% OUTSIDE {problems} expecting retrieval actually invokes this environment's
% begin-code, which would then run away scanning for \end{problem}. \begin sets
% \@currenvir to "problem"; if it isn't, we were not entered via \begin{problem},
% so raise a targeted error instead. Fail-safe: only errors when we can prove the
% environment opener was reached outside a \begin{problem}.
\newenvironment{problem}[1]{%
	\def\@texlib@penv{problem}%
	\ifx\@currenvir\@texlib@penv\else
		\PackageError{texlib-problembank}%
			{\protect\problem\space used outside \protect\begin{problems}}%
			{To DEFINE a bank problem, use the environment:^^J%
			 \space\space\string\begin{problem}{id} ... \string\end{problem}.^^J%
			 To RETRIEVE one, use \string\getproblem{filter} anywhere, or^^J%
			 \space\space\string\problem[pts]{filter} INSIDE \string\begin{problems}.^^J%
			 It looks like you wrote a bare \string\problem outside {problems}.}%
	\fi
	\def\@problem@id{#1}%
	% Record the bank-file line number NOW (before \Collect@Body reads ahead to
	% \end{problem}).  By the time define_problem_from_env() runs, \inputlineno
	% has advanced to the \end{problem} line, so we snapshot it here instead.
	\pbank@lua{pbank_problem_start_line = tex.inputlineno}%
	\@problem@scan
}{%
	% End-code is empty; \Collect@Body handles everything at \end{problem}.
}

% \getproblem{query}  — unified retrieve/query command.
%   Plain id:      \getproblem{linear_eq}
%   Key=val query: \getproblem{topic=algebra, diff=hard}
%   If no '=' is found the whole string is treated as a problem id.
%   Multiple key=value pairs are ANDed; one random match is typeset.
%   On no match: emits a visible placeholder and a log warning.
\NewDocumentCommand{\getproblem}{m}{%
	\pbank@lua{get_problem('\luaescapestring{#1}')}%
}

% Backward-compat aliases
\let\useproblem\getproblem
\NewDocumentCommand{\reqproblem}{m}{\getproblem{#1}}

% LaTeX naming note: \begin{problem} (definition environment) uses \problem
% as its begin-code, so a global \problem item command would shadow it.
% Solution: define the item command once under \@problem@item, then let
% \begin{problems} (defined by each class) locally swap
% \problem <-> \@problem@item and restore on exit.
%   - \begin{problem}{id}[meta] works everywhere OUTSIDE {problems}
%   - \problem[pts][stretch]{filter}[fix] works INSIDE {problems}

% \ppart — problem-part item for use inside \begin{problem} bodies.
%   Always delegates to exam class's \part (the list-item command inside
%   \begin{parts}).  When the enclosing \problem item carries per-part
%   point values (e.g. \problem[2,3]{id}), each \ppart call automatically
%   injects the corresponding point annotation via the Lua part-index state.
\NewDocumentCommand{\ppart}{}{\pbank@lua{pbank_inject_part()}}

% \@problem@item[points][stretch]{filter}[fix]
%   The actual item command implementation — defined once at class load.
%   #1 = points  (optional, default empty = no point label)
%             Single value: annotates the \question (e.g. \problem[5]{id})
%             Comma-sep:    distributed to \ppart calls (e.g. \problem[2,3]{id})
%   #2 = stretch (optional, default 1 = \vspace{\stretch{1}} after body)
%             Per-part stretch is not yet supported; first value is used.
%   #3 = filter  (mandatory, forwarded verbatim to get_problem)
%   #4 = fix     (optional trailing bracket, default empty)
%             Key=value list of variable overrides applied to the problem
%             body. e.g. \problem{quadratic}[a=1, b=2, c=3] fixes a, b, c
%             so the bank's own \setrng/\setvar/\pick* on those names are
%             skipped. Other variables in the bank entry remain random.
%             Values that parse as numbers are stored as Lua numbers; all
%             others are stored as trimmed strings.  Engine-side scope
%             management is via push_scope/pop_scope so each problem starts
%             with a clean fixed[] table.
%
%   All token output (\question, problem content, stretch) is generated inside
%   Lua via tex.print, avoiding pre-tokenized-token interactions with the
%   comment package's \excludecomment catcode scanner.
\NewDocumentCommand{\@problem@item}{O{} O{1} m O{}}{%
	\pbank@lua{pbank_problem_item(
		'\luaescapestring{#1}',
		'\luaescapestring{#2}',
		'\luaescapestring{#3}',
		'\luaescapestring{#4}'
	)}%
}

% \loadbank{path}  — explicitly load a problem bank file.
%
% Calls pbank_set_bankfile() so the engine records the bank-file path on
% every problem.  The path enables the SyncTeX bank-file redirect: clicking
% a typeset problem in the PDF jumps to its \begin{problem} block in the
% real bank source, not to a generated temp file.
%
% The redirect is active for every build mode — single-version (quiz,
% edit-mode autoexam) and multi-version (autoexam_run_versions) alike — so all
% of them serve one reused scratch file per job and land inverse search in the
% bank.  Multi-version formerly set pbank_suppress_redirect to dodge an
% input-stack overflow; the texlib_synctex.lua helper closes each \@@input at
% EOF, so the inputs pop and the depth never accumulates (verified with a
% 3-version exam under a deliberately low max_in_open).
\NewDocumentCommand{\loadbank}{m}{%
	\pbank@lua{pbank_set_bankfile('\luaescapestring{#1}')}%
	\input{#1}%
	% Restore the previous bank context so a \begin{problem} written directly in
	% the document after this \loadbank is attributed to the document, not the
	% bank (its inverse search should land in the document's own source).
	\pbank@lua{pbank_clear_bankfile()}%
}

% \pbank@load@coursebank — auto-load a course-level bank, called by each class
% from its own \AtBeginDocument (not registered here, so non-assessment
% consumers like didactic are unaffected). Tries the coursemeta bank-path
% (literal first for legacy document-relative values, then coursemeta-relative),
% then a sibling bank.tex. The CWD probe uses lfs rather than \IfFileExists so a
% recursive TEXINPUTS entry can't silently match a stray library sample bank.
\newcommand{\pbank@load@coursebank}{%
	\@ifundefined{GetBankPath}{}{%
		\edef\@tmpbankpath{\GetBankPath}%
		\ifx\@tmpbankpath\empty\else
			\IfFileExists{\@tmpbankpath}{%
				\loadbank{\@tmpbankpath}%
			}{%
				\@ifundefined{GetCourseMetaDir}{%
					\loadbank{\@tmpbankpath}%
				}{%
					\edef\@tmpbankresolved{\GetCourseMetaDir\@tmpbankpath}%
					\IfFileExists{\@tmpbankresolved}{%
						\loadbank{\@tmpbankresolved}%
					}{%
						\loadbank{\@tmpbankpath}%
					}%
				}%
			}%
		\fi
	}%
	\directlua{%
		if lfs.attributes('bank.tex', 'mode') == 'file' then
			tex.print('\string\\loadbank{bank.tex}')
		end
	}%
}

% \importproblem{path}{overrides}  — import a standalone problem file with
%   Lua variable overrides (e.g. {a=5, b=10}) in an isolated scope.
%
%   The overrides are applied via pbank_apply_fix() so the imported file's
%   own \setrng/\setvar/\calcvar/\pick* on those names become no-ops, matching
%   the lock semantics of \problem{id}[a=1,b=2].  push_scope/pop_scope wrap
%   the whole import so neither the override values nor the fixed[] markings
%   leak back to surrounding code.
\newcommand{\importproblem}[2]{%
	\begingroup
	\pbank@lua{push_scope() pbank_apply_fix('\luaescapestring{#2}')}%
	\input{#1}%
	\pbank@lua{pop_scope()}%
	\endgroup
}

% \workbox{n} — reserved blank space below a problem (engine emits this).
%   Default: stretchy \vspace.  autoexam.cls overrides to hide the space in
%   solution builds (so a key copy doesn't get blank pages).
\providecommand{\workbox}[1]{\vspace{\stretch{#1}}}

% \autoexam@problem@sep — separator between consecutive problems on the same
%   page (engine emits this for problems 2+ on each page).  Default: a plain
%   \par\medskip; autoexam.cls overrides with a full-width rule.
\providecommand{\autoexam@problem@sep}{\par\medskip}

% \begin{problems} ... \end{problems}
%   Drop-in replacement for {questions} that accepts \problem items (the
%   {questions} environment is preserved for backward compat).  The core is
%   identical in every class: it tracks the first problem on each page (for the
%   inter-problem separator), patches \newpage to reset that flag, opens
%   {questions}, and swaps \problem <-> \@problem@item for the body.
%
%   Class-specific page policy is injected through two overridable hooks, both
%   no-ops by default:
%     \problems@begin@hook — runs before {questions} opens.  autoexam.cls fills
%        it with \clearpage, the page-counter reset, the problem-style
%        header/footer slots, and a single-use guard; quiz.cls leaves it empty
%        (quizzes have no cover page or separate "X of N" numbering, so the
%        environment must NOT clear the page or reset the counter).
%     \problems@end@hook   — runs after {questions} closes.  autoexam.cls uses
%        it to place \label{@lastqpage} for the "X of N" footer.
%   The hooks run INSIDE the environment's group, so a plain \def a class makes
%   in \problems@begin@hook is local to the environment (use \global for slots
%   that must outlive it — see autoexam.cls).
\providecommand{\problems@begin@hook}{}
\providecommand{\problems@end@hook}{}
\newenvironment{problems}{%
	\problems@begin@hook
	% ---- inter-problem separator: first problem on a page gets no rule -------
	\pbank@lua{pbank_first_on_page = true}%
	% Patch \newpage so crossing a page boundary resets the "first on page" flag.
	\let\@problems@saved@newpage\newpage
	\renewcommand{\newpage}{%
		\@problems@saved@newpage
		\pbank@lua{pbank_first_on_page = true}%
	}%
	% ---- start questions list ------------------------------------------------
	\begin{questions}%
	\let\@saved@problem\problem
	\let\problem\@problem@item
}{%
	\let\problem\@saved@problem
	\let\newpage\@problems@saved@newpage
	\end{questions}%
	\problems@end@hook
}

\endinput
