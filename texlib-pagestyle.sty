\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{texlib-pagestyle}[2026/05/26 v1.0 TeXLib exam-class page-style helpers]

% ==============================================================================
% texlib-pagestyle.sty — shared page-style scaffolding for TeXLib classes that
% build on the `exam` document class (autoexam, quiz)
% ==============================================================================
%
% The `exam` class ships with the `headandfoot` page style plus separate hooks
% for first-page and running-page rules.  autoexam.cls and quiz.cls both wire
% the same 4-call bundle:
%
%     \pagestyle{headandfoot}
%     \firstpagefootrule
%     \runningheadrule
%     \runningfootrule
%
% This file packages that boilerplate behind \SetTeXLibExamRules so the two
% classes stay in lock-step.  Headers and footers themselves (the strings in
% \firstpageheader / \runningfooter / etc.) remain class-specific — exam title
% block vs. quiz name-field is a design decision per class, not a candidate
% for extraction.  This file is the sibling of texlib-footer.sty, which
% serves the fancyhdr-based classes (didactic, pset) the same way.
%
% Usage:
%     \RequirePackage{texlib-pagestyle}    % once, in the class preamble
%     ...
%     \SetTeXLibExamRules                  % install pagestyle + running rules
%     % then set per-class header / footer content
%     \firstpagefooter{...}{...}{...}
%     \runningheader{...}{...}{...}
%     \runningfooter{...}{...}{...}
%
% Classes that also want a first-page header rule (e.g. quiz's name field)
% add \firstpageheadrule after the helper:
%     \SetTeXLibExamRules
%     \firstpageheadrule

% Symmetric rule bleed for the exam-family. The fancyhdr classes (didactic,
% pset, ...) widen their header + footer rules \texlibrulebleed=24pt into BOTH
% margins via \fancyhfoffset[LR] (see texlib-footer.sty) so the rule ends line
% up with the section-hang. exam's `headandfoot` style draws its head/foot rules
% flush to \textwidth instead, so without help they fall 24pt short on each side.
% \fancyhfoffset can't reach them (fancyhdr isn't the active style here), and
% exam's own \extrawidth would also widen the question BODY -- unwanted. So we
% patch exam's four head/foot renderers to slide left by the bleed and draw into
% a locally widened \textwidth, extending the rule (and L/R slot text) 24pt past
% the body on each side while leaving the body column untouched. Keep this value
% in sync with \texlibrulebleed / \texlibsectionhang (both 24pt).
% We wrap exam's four head/foot renderers rather than reproduce them: \let the
% originals and re-issue each inside \texlib@exambleed, which draws the renderer
% into a \textwidth locally widened by 2*bleed (and shifted left by bleed), so the
% rule + L/R slot text extend the bleed past the body on each side. Wrapping (not
% copying) keeps us forward-compatible if exam.cls changes those definitions.
\makeatletter
\newlength{\texlibexamrulebleed}
\setlength{\texlibexamrulebleed}{24pt}
\newcommand{\texlib@exambleed}[1]{%
	\hb@xt@\textwidth{%
		\hskip-\texlibexamrulebleed
		\begingroup
			\advance\textwidth by 2\texlibexamrulebleed
			#1%
		\endgroup
		\hss}%
}
\let\texlib@orig@fullhead\@fullhead
\let\texlib@orig@runfullhead\run@fullhead
\let\texlib@orig@fullfoot\@fullfoot
\let\texlib@orig@runfullfoot\run@fullfoot
\renewcommand*\@fullhead{\texlib@exambleed{\texlib@orig@fullhead}}
\renewcommand*\run@fullhead{\texlib@exambleed{\texlib@orig@runfullhead}}
\renewcommand*\@fullfoot{\texlib@exambleed{\texlib@orig@fullfoot}}
\renewcommand*\run@fullfoot{\texlib@exambleed{\texlib@orig@runfullfoot}}
\makeatother

% \SetTeXLibExamRules — activate the exam-class `headandfoot` style and the
%   conventional rule set (first-page footer + running head + running foot).
%   Idempotent; safe to call from inside \AtBeginDocument or at class load.
\providecommand{\SetTeXLibExamRules}{%
	\pagestyle{headandfoot}%
	\firstpagefootrule
	\runningheadrule
	\runningfootrule
}

\endinput
