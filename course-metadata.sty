% course-metadata.sty
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{course-metadata}[2026/06/25 v8.2 Layered Metadata Engine]

\RequirePackage{expl3}
\RequirePackage{xparse}
\RequirePackage{etoolbox}        % \AtEndPreamble, for the preamble-file auto-load

\ExplSyntaxOn

% #1 = CamelCase getter suffix, #2 = raw key name.  The key name is baked into
% the body here, so the getter never depends on \l_keys_key_tl being live.
% Each field gets a symmetric pair: \Get<Camel> reads it and \Set<Camel>{v} sets
% it. \Set... is a thin \metasetup wrapper, so every field-setter routes through
% the one canonical entry point. It forward-references \metasetup (defined below)
% — fine, the body is only expanded at use time. Both halves are guarded so a
% hand-rolled \Get.../\Set... (e.g. the derived \GetTerm) is never clobbered.
\cs_new_protected:Npn \meta_create_getter:nn #1 #2 {
	\cs_if_exist:cF { Get#1 } {
		\exp_args:Nc \NewExpandableDocumentCommand { Get#1 } { } {
			\tl_use:c { g__meta_#2_tl }
		}
	}
	\cs_if_exist:cF { Set#1 } {
		\exp_args:Nc \NewDocumentCommand { Set#1 } { +m } {
			\metasetup { #2 = {##1} }
		}
	}
}
\cs_generate_variant:Nn \meta_create_getter:nn { VV }

\cs_new_protected:Npn \meta_create_var:nn #1 #2 {
	\tl_new:c { g__meta_#1_tl }
	\meta_create_getter:nn {#2} {#1}
}

\NewExpandableDocumentCommand{\GetTerm}{ } {
	\tl_if_empty:cTF { g__meta_term_tl }
		{ \GetSeason \space \GetYear }
		{ \tl_use:c { g__meta_term_tl } }
}

\meta_create_var:nn { institution }    { Institution }
\meta_create_var:nn { instructor }     { Instructor }
\meta_create_var:nn { term }           { Term }
\meta_create_var:nn { year }           { Year }
\meta_create_var:nn { season }         { Season }
\meta_create_var:nn { course-subject } { CourseSubject }
\meta_create_var:nn { course-number }  { CourseNumber }
\meta_create_var:nn { course-title }   { CourseTitle }
\meta_create_var:nn { course-section } { CourseSection }
\meta_create_var:nn { course-room }    { CourseRoom }
\meta_create_var:nn { lecture-days }   { LectureDays }
\meta_create_var:nn { lecture-times }  { LectureTimes }
\meta_create_var:nn { start-date }     { StartDate }
\meta_create_var:nn { end-date }       { EndDate }
\meta_create_var:nn { final-date }     { FinalDate }
\meta_create_var:nn { final-time }     { FinalTime }
% Per-exam dates (exam1-date .. exam5-date). autoexam picks up exam<N>-date when
% its exam-number matches N (an explicit local exam-date still wins); the
% syllabus \examdatetable lists whichever are set. final-date above is the final.
\meta_create_var:nn { exam1-date }     { ExamOneDate }
\meta_create_var:nn { exam2-date }     { ExamTwoDate }
\meta_create_var:nn { exam3-date }     { ExamThreeDate }
\meta_create_var:nn { exam4-date }     { ExamFourDate }
\meta_create_var:nn { exam5-date }     { ExamFiveDate }
\meta_create_var:nn { bank-path }      { BankPath }
\meta_create_var:nn { gradebook-path } { GradebookPath }
\meta_create_var:nn { preamble-file }  { PreambleFile }
% Per-class instructions-file keys. They live here (not in each class) so a
% course can point every quiz/exam/card-set/pset at one file course-wide from
% coursemeta.tex — coursemeta is read at this package's load, before any class
% body, so a key defined only in the class would miss it. texlib-instructions.sty
% consumes the matching \Get<Prefix>InstructionsFile getters.
\meta_create_var:nn { quiz-instructions-file }  { QuizInstructionsFile }
\meta_create_var:nn { exam-instructions-file }  { ExamInstructionsFile }
\meta_create_var:nn { bingo-instructions-file } { BingoInstructionsFile }
\meta_create_var:nn { pset-instructions-file }  { PsetInstructionsFile }

% Promoted class fields (course-wide defaults). These were historically options
% of a single document class (the syllabus's instructor-contact and scheduling
% fields). Declaring them here — before \LoadCourseMeta — lets a course set them
% ONCE in coursemeta.tex; a document's class options still override. The consuming
% class reads the \Get<Camel> getter instead of a private store. short-title gets
% a store only (no auto getter): the syllabus exposes \GetShortTitle with its own
% \GetCourse fallback.
\meta_create_var:nn { email }          { Email }
\meta_create_var:nn { office }         { Office }
\meta_create_var:nn { office-hours }   { OfficeHours }
\meta_create_var:nn { organizer }      { Organizer }
\meta_create_var:nn { class-time }     { ClassTime }
\meta_create_var:nn { class-time-alt } { ClassTimeAlt }
\tl_new:c { g__meta_short-title_tl }

\keys_define:nn { meta } {
	institution     .tl_gset:c = { g__meta_institution_tl },
	instructor      .tl_gset:c = { g__meta_instructor_tl },
	term            .tl_gset:c = { g__meta_term_tl },
	year            .tl_gset:c = { g__meta_year_tl },
	season          .tl_gset:c = { g__meta_season_tl },
	course-subject  .tl_gset:c = { g__meta_course-subject_tl },
	course-number   .tl_gset:c = { g__meta_course-number_tl },
	course-title    .tl_gset:c = { g__meta_course-title_tl },
	course-section  .tl_gset:c = { g__meta_course-section_tl },
	course-room     .tl_gset:c = { g__meta_course-room_tl },
	lecture-days    .tl_gset:c = { g__meta_lecture-days_tl },
	lecture-times   .tl_gset:c = { g__meta_lecture-times_tl },
	start-date      .tl_gset:c = { g__meta_start-date_tl },
	end-date        .tl_gset:c = { g__meta_end-date_tl },
	final-date      .tl_gset:c = { g__meta_final-date_tl },
	final-time      .tl_gset:c = { g__meta_final-time_tl },
	exam1-date      .tl_gset:c = { g__meta_exam1-date_tl },
	exam2-date      .tl_gset:c = { g__meta_exam2-date_tl },
	exam3-date      .tl_gset:c = { g__meta_exam3-date_tl },
	exam4-date      .tl_gset:c = { g__meta_exam4-date_tl },
	exam5-date      .tl_gset:c = { g__meta_exam5-date_tl },
	bank-path       .tl_gset:c = { g__meta_bank-path_tl },
	gradebook-path  .tl_gset:c = { g__meta_gradebook-path_tl },
	preamble-file   .tl_gset:c = { g__meta_preamble-file_tl },
	quiz-instructions-file  .tl_gset:c = { g__meta_quiz-instructions-file_tl },
	exam-instructions-file  .tl_gset:c = { g__meta_exam-instructions-file_tl },
	bingo-instructions-file .tl_gset:c = { g__meta_bingo-instructions-file_tl },
	pset-instructions-file  .tl_gset:c = { g__meta_pset-instructions-file_tl },
	% Promoted class fields (course-wide defaults; see the var block above).
	email            .tl_gset:c = { g__meta_email_tl },
	instructor-email .tl_gset:c = { g__meta_email_tl },        % alias for email
	office           .tl_gset:c = { g__meta_office_tl },
	office-hours     .tl_gset:c = { g__meta_office-hours_tl },
	organizer        .tl_gset:c = { g__meta_organizer_tl },
	class-time       .tl_gset:c = { g__meta_class-time_tl },
	class-time-alt   .tl_gset:c = { g__meta_class-time-alt_tl },
	short-title      .tl_gset:c = { g__meta_short-title_tl },
	syllabus-title   .tl_gset:c = { g__meta_short-title_tl },  % alias for short-title
}

% Warn on terminal when a field is auto-created (catches typos like instuctor=).
% Documents that use custom keys deliberately call \MetaAllowCustomKeys to
% downgrade this to a log-only note.
\bool_new:N \g__meta_warn_custom_bool
\bool_gset_true:N \g__meta_warn_custom_bool

% Catch-all: any key not listed above auto-vivifies a g__meta_<key>_tl store
% and a matching \Get<Key> getter.  Must be `unknown`, not `.unknown` — the
% leading-dot form is silently inert and never registers as the handler.
\keys_define:nn { meta } {
	unknown .code:n = {
		% \l_tmpa_tl holds the raw key value (my-custom-field); keep it intact
		% for the store name.  \l_tmpb_tl is mangled into the CamelCase getter.
		\tl_set:NV \l_tmpa_tl \l_keys_key_tl
		\tl_if_exist:cF { g__meta_ \l_tmpa_tl _tl } {
			\tl_new:c { g__meta_ \l_tmpa_tl _tl }
			% Loud by default so a typo'd key surfaces; quiet (log-only) once the
			% document has opted in to custom keys.  Either way it stays traceable.
			\bool_if:NTF \g__meta_warn_custom_bool
				{ \PackageWarning{course-metadata}
					{Auto-creating~metadata~field~'\l_tmpa_tl'.
					 \MessageBreak If~this~is~a~typo,~fix~it;~if~intentional,~call
					 \MessageBreak \string\MetaAllowCustomKeys\space to~silence~this} }
				{ \PackageInfo{course-metadata}
					{Auto-creating~metadata~field~'\l_tmpa_tl'} }
		}
		\tl_gset:cn { g__meta_ \l_tmpa_tl _tl } { #1 }
		\tl_set:NV \l_tmpb_tl \l_tmpa_tl
		\regex_replace_all:nnN { - } { \  } \l_tmpb_tl
		\tl_set:Nf \l_tmpb_tl { \text_titlecase_all:n { \l_tmpb_tl } }
		\regex_replace_all:nnN { \s } { } \l_tmpb_tl
		% Pass values (not tokens) so the key name is baked into the getter body.
		\meta_create_getter:VV \l_tmpb_tl \l_tmpa_tl
	}
}

% Custom-key warning toggle.  Call \MetaAllowCustomKeys before the \metasetup
% calls that introduce custom keys (e.g. atop coursemeta.tex).
\NewDocumentCommand{\MetaAllowCustomKeys}{}{ \bool_gset_false:N \g__meta_warn_custom_bool }
\NewDocumentCommand{\MetaWarnCustomKeys}{}{ \bool_gset_true:N \g__meta_warn_custom_bool }

\NewDocumentCommand{\metasetup}{ +m } {
	\tl_set:Nn \l_tmpa_tl { #1 }
	\regex_replace_all:nnN { \c{par} } { } \l_tmpa_tl
	\keys_set:nV { meta } \l_tmpa_tl
}

% \meta is just an alias of \metasetup, the canonical setter — defined here
% (after \metasetup) so it copies the real command, not a duplicate of its body.
% Caveat: doc/ltxdoc also define \meta; a class or document that loads either
% AFTER this package shadows the alias, in which case call \metasetup directly.
% No internal TeXLib code depends on \meta, so that shadowing is harmless.
\NewCommandCopy \meta \metasetup

% \GetCourse -- the full course name "<Subject> <Number> <Title>", e.g.
% "Math 181 Calculus I". The convention is a bare course-title ("Calculus I")
% with subject/number separate; \GetCourse composes them with plain spaces (no
% colon) so the same string serves titles, headers, and footers uniformly.
\NewExpandableDocumentCommand{\GetCourse}{ } {
	\cs_if_exist:NT \GetCourseSubject { \GetCourseSubject \space }
	\cs_if_exist:NT \GetCourseNumber  { \GetCourseNumber \space }
	\cs_if_exist:NT \GetCourseTitle   { \GetCourseTitle }
}

\NewExpandableDocumentCommand{\GetCourseShort}{ } {
	\cs_if_exist:NT \GetCourseSubject { \GetCourseSubject \space }
	\cs_if_exist:NT \GetCourseNumber  { \GetCourseNumber }
}

\NewDocumentCommand{\IfMetaSet}{ m +m +m } {
	\tl_if_exist:cTF { g__meta_#1_tl }
		{ \tl_if_empty:cTF { g__meta_#1_tl } { #3 } { #2 } }
		{ #3 }
}

% \GetTermSection -- shared right-header content for the term-keyed classes
% (syllabus, pset, report-card, autoexam): the term, then "Section <n>" when a
% course-section is set. Either part is omitted when empty, with a single space
% between them only when both are present.
\tl_new:N \l__meta_termsec_tl
\NewDocumentCommand{\GetTermSection}{}{
	\tl_set:Ne \l__meta_termsec_tl { \GetTerm }
	\tl_if_blank:VF \l__meta_termsec_tl { \tl_use:N \l__meta_termsec_tl }
	\IfMetaSet{course-section}{
		\tl_if_blank:VF \l__meta_termsec_tl { \space }
		Section~\GetCourseSection
	}{}
}

\bool_new:N \g__meta_found_bool
\tl_new:N   \g__meta_path_tl
\tl_new:N   \g__meta_dir_tl
\clist_map_inline:nn { ., .., ../.., ../../.. } {
	\file_if_exist:nT { #1/coursemeta.tex } {
		\tl_gset:Nn \g__meta_path_tl { #1/coursemeta.tex }
		\tl_gset:Nn \g__meta_dir_tl  { #1/ }
		\bool_gset_true:N \g__meta_found_bool
		\clist_map_break:
	}
}
% \GetCourseMetaDir returns the prefix walked to find coursemeta.tex,
% with a trailing slash (e.g. "./", "../", "../../").  Consumers prepend
% this to coursemeta-relative paths (such as bank-path) so the same
% canonical string resolves correctly regardless of how deep the
% compiling document lives below coursemeta.
\NewExpandableDocumentCommand{\GetCourseMetaDir}{ } {
	\tl_use:N \g__meta_dir_tl
}
% Diagnostic when no coursemeta.tex turns up: the standard getters stay defined
% (they expand empty), but custom \Get<Key> keys that only a coursemeta would
% mint surface as confusing "undefined control sequence" errors downstream. A
% warning (not an error) keeps the class-options-only / \metasetup-only workflow
% working while pointing at the likely cause.
\msg_new:nnn { course-metadata } { no-coursemeta }
	{
		No~coursemeta.tex~found~(looked~in~.,~..,~../..,~../../..~relative~to~
		the~job).~Course~metadata~will~be~empty~unless~provided~via~class~
		options~or~the~metasetup~command.~See~
		examples/Math181-Fall2026/coursemeta.tex~for~the~expected~file.
	}
\NewDocumentCommand{\LoadCourseMeta}{}{
	\bool_if:NTF \g__meta_found_bool
		{ \input{ \g__meta_path_tl } }
		{ \msg_warning:nn { course-metadata } { no-coursemeta } }
}

% ------------------------------------------------------------------------------
% \MetaHumanMonthDay{<value>} -- render a numeric "M-D" date (the form final-date
% must take so the schedule's date math can parse it) as a human-readable
% "<Mon> <D>, <year>", matching the free-form exam<N>-date keys. The syllabus
% \examdatetable and the autoexam Final-exam cover use it so a schedule-parseable
% final-date still displays like the other exam dates, single-sourcing the month
% names. Fully expandable. A value that expands EMPTY yields nothing; the value
% is otherwise assumed to be "M-D" (final-date always is).
% ------------------------------------------------------------------------------
\cs_new:Npn \__meta_month_abbr:n #1 {
	\str_case:nnF {#1}
		{ {1}{Jan} {2}{Feb} {3}{Mar} {4}{Apr}  {5}{May}  {6}{Jun}
		  {7}{Jul} {8}{Aug} {9}{Sep} {10}{Oct} {11}{Nov} {12}{Dec} }
		{#1}
}
\cs_new:Npn \__meta_md_split:w #1-#2\q_stop {
	\__meta_month_abbr:n {#1}~#2,~\GetYear
}
\cs_new:Npn \__meta_md_human:n #1 {
	\tl_if_blank:nTF {#1} { } { \__meta_md_split:w #1 \q_stop }
}
\NewExpandableDocumentCommand{\MetaHumanMonthDay}{ m } {
	\exp_args:Ne \__meta_md_human:n { #1 }
}

\ExplSyntaxOff

% ==============================================================================
% Backward-compat \the* aliases
% ==============================================================================
% Several TeXLib document classes (autoexam, quiz, didactic, pset, ...) and
% documents written against them refer to course fields as \theCourseNumber,
% \theCourseTitle, etc. — a habit that pre-dates the v8.1 \Get* API.  We
% expose the aliases here as \providecommand so any class or document that
% \renewcommand's them keeps working, and classes never collide by trying to
% \newcommand a name that another class also wanted.
\providecommand{\theCourseSubject}{\GetCourseSubject}
\providecommand{\theCourseNumber}{\GetCourseNumber}
\providecommand{\theCourseTitle}{\GetCourseTitle}
\providecommand{\theCourseSection}{\GetCourseSection}
\providecommand{\theCourseRoom}{\GetCourseRoom}
\providecommand{\theCourse}{\GetCourse}
\providecommand{\theInstructor}{\GetInstructor}
\providecommand{\theInstitution}{\GetInstitution}
\providecommand{\theSchool}{\GetInstitution}      % UNR-friendly alias
\providecommand{\theSeason}{\GetSeason}
\providecommand{\theYear}{\GetYear}
\providecommand{\theTerm}{\GetTerm}

\LoadCourseMeta

% Auto-load a course-wide preamble file when `preamble-file` is set in
% coursemeta.tex. The path is resolved coursemeta-relative (\GetCourseMetaDir
% prepended, like bank-path) and the input is deferred to \AtEndPreamble so the
% document class is fully loaded first. Lets a course point every document at one
% shared preamble instead of \input-ing it by hand; a no-op when the key is unset.
\AtEndPreamble{%
	\IfMetaSet{preamble-file}{\input{\GetCourseMetaDir\GetPreambleFile}}{}%
}
