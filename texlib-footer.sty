% texlib-footer.sty
% Shared footer module for TeXLib document classes (didactic, pset, ...).
%
% Provides the unified bottom-of-page layout:
%
%     [ \GetCourse ]   [ page X of Y ]   [ \GetInstitution ]
%
% Headers are intentionally NOT touched here -- those remain class-specific
% (lecture notes use unit/instructor/section; exams use exam number/version;
% etc.).  Classes opt in by:
%
%     \RequirePackage{texlib-footer}    % once, in the class preamble
%     ...
%     \pagestyle{fancy}                 % the class sets up fancy + headers
%     \SetTeXLibFooter                  % installs the shared footer
%
% For a page style that keeps only the footer (title/first pages that suppress
% the header), use \TeXLibFooterOnlyPagestyle{<name>} (defined below).
%
% The left slot shows \GetCourse, the full "<Subject> <Number> <Title>" name
% (e.g. "Math 181 Calculus I"). course-metadata.sty must be loaded before
% \SetTeXLibFooter is invoked, so \GetCourse and \GetInstitution exist.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{texlib-footer}[2026/05/10 v1.0 Shared TeXLib footer]

\RequirePackage{fancyhdr}
\RequirePackage{lastpage}

\newcommand{\SetTeXLibFooter}{%
	\fancyfoot[L]{\GetCourse}%
	\fancyfoot[C]{\thepage\ of \pageref{LastPage}}%
	\fancyfoot[R]{\GetInstitution}%
	\renewcommand{\footrulewidth}{0.4pt}%
}

% \TeXLibFooterOnlyPagestyle{<name>} -- a page style carrying only the shared
% footer (no header rule); for title/first pages that suppress the header.
\newcommand{\TeXLibFooterOnlyPagestyle}[1]{%
	\fancypagestyle{#1}{\fancyhf{}\SetTeXLibFooter\renewcommand{\headrulewidth}{0pt}}%
}

% \SetTeXLibHeader{L}{C}{R} -- the header analog of \SetTeXLibFooter. Places the
% three slots and the shared 0.4pt rule, so classes stop hand-writing
% \fancyhead[L/C/R] + \headrulewidth. Content stays class-specific (the center
% slot is usually \TeXLibBuildBadge from texlib-build); structure + rule are
% centralized here. Call after \fancyhf{} and \pagestyle{fancy}.
%
% fancyhdr anchors the three slots independently (the center slot is centered
% on \headwidth no matter how wide its neighbors get), so a long L or R slot
% -- e.g. a lengthy \rightmark in a section-bearing class -- would run straight
% under a centered build badge. The center slot therefore goes through a
% shipout-time guard (marks only have their final value there): it prints only
% when both side slots keep \texlibheaderclearance of air to the centered box.
% The side slots carry the real navigation content, so the badge yields. An
% empty center slot (student builds, classes with no badge) takes the
% short-circuit branch and renders exactly as it always has.
\newlength{\texlibheaderclearance}
\setlength{\texlibheaderclearance}{10pt}
\newcommand{\texlib@guardedcenter}[3]{%
	\settowidth{\@tempdima}{#2}%
	\ifdim\@tempdima=\z@
		#2%
	\else
		% widest a side slot may grow before crowding the centered one
		\@tempdimb=\dimexpr(\headwidth-\@tempdima)/2-\texlibheaderclearance\relax
		\settowidth{\@tempdima}{#1}%
		\ifdim\@tempdima>\@tempdimb\else
			\settowidth{\@tempdima}{#3}%
			\ifdim\@tempdima>\@tempdimb\else
				#2%
			\fi
		\fi
	\fi
}
\newcommand{\SetTeXLibHeader}[3]{%
	\fancyhead[L]{#1}%
	\fancyhead[C]{\texlib@guardedcenter{#1}{#2}{#3}}%
	\fancyhead[R]{#3}%
	\renewcommand{\headrulewidth}{0.4pt}%
}

% Symmetric rule bleed: widen the header AND footer rules by \texlibrulebleed
% into BOTH margins, so every class's rules are the same length and symmetric
% about the page midpoint, with the L/R slot text sitting flush at the rule
% ends. The bleed equals the section hang (\texlibsectionhang = 24pt), so the
% LEFT end lands exactly on the hung-heading line while the right end mirrors
% it. Keep this value in sync with \texlibsectionhang. Call once, after
% \pagestyle{fancy}. (\fancyhfoffset adjusts head + foot together.) The
% classes that load texlib-sectionhang (didactic, pset, report-card, syllabus)
% get their bleed from its [LR] offset instead, so they must NOT also call
% \TeXLibRuleBleed; only the no-section classes (bingo) call it.
\newlength{\texlibrulebleed}
\setlength{\texlibrulebleed}{24pt}
\newcommand{\TeXLibRuleBleed}{\fancyhfoffset[LR]{\texlibrulebleed}}

\endinput
