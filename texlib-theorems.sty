% texlib-theorems.sty
% Shared theorem-box styling for the TeXLib teaching library.
%
% Provides the tcolorbox STYLES only — not the \newtheorem declarations.
% Each class keeps its own theorem environment set and numbering scheme
% (didactic numbers Theorem by section and carries a large taxonomy;
% pset numbers flat and carries a smaller one), but both bind their
% environments to these shared styles via \tcolorboxenvironment.
%
% The look is the "colored thin left rule + ~2% background tint"
% aesthetic that originated in didactic.cls. During the May 2026
% consolidation pass this was chosen as the canonical TeXLib theorem
% look; pset.cls's older sharp-black-frame `psetstyle` is retired.
%
% Styles exposed (all built on `texlibbase`):
%   texlibtheorem      red     — Theorem / Lemma / Corollary / Conjecture
%   texlibproposition  violet  — Proposition
%   texlibdefinition   blue    — Definition / Convention
%   texlibprocedure    teal    — Procedure
%   texlibexample      black   — Example / Exercise (no tint; rule only)
%   texlibquestion     orange  — Question / Challenge
%   texlibnote         gray    — Note / Notation / Recall
%
% GEOMETRY (consolidated 2026/05/30). Every rule is the SAME width
% (\texlibrulewidth) and the SAME horizontal position. The box bleeds
% \texlibruleshift into the left margin (`grow to left by`) while keeping
% \texlibruleshift of inner left padding, so the body text lands back on the
% ordinary text margin — i.e. aligned with non-ruled environments such as
% `remark` and plain paragraphs — and the rule + tint sit out in the margin.
% Change \texlibrulewidth / \texlibruleshift below to retune all styles at
% once; the solution / dashed-answer rules in didactic.cls and pset.cls read
% the same two values.
%
% A class applies them like:
%   \tcolorboxenvironment{theorem}{texlibtheorem}
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{texlib-theorems}[2026/06/01 v1.2 TeXLib shared theorem styling]
%
% Customization: \texlibtheoremsetup{ rule=false, tint=false,
% theorem-color=purple, ... } toggles the left rule / background tint globally
% or recolours individual families.  See the "customization" section below.

\RequirePackage[many]{tcolorbox}
\RequirePackage{amsthm}

% Single source of truth for every TeXLib left rule. Consumed here and by the
% solution / hint / dashed-answer boxes in didactic.cls and pset.cls.
\newcommand{\texlibrulewidth}{1.5pt}
\newlength{\texlibruleshift}\setlength{\texlibruleshift}{8pt}

% Shared base: breakable, no full frame, gentle asymmetric padding. The box is
% grown \texlibruleshift into the left margin and carries \texlibruleshift of
% inner left padding, so body text returns to the ordinary margin while the
% rule lives in the margin.
\tcbset{
	texlibbase/.style={
		enhanced jigsaw, breakable,
		sharp corners, frame hidden,
		boxrule=0pt,
		grow to left by=\texlibruleshift,
		left=\texlibruleshift, right=4pt, top=4pt, bottom=4pt,
		before skip=10pt, after skip=10pt,
	},
}

% ==============================================================================
% Per-family appearance + customization
% ==============================================================================
% Each family carries three tunables — its base hue, its tint percentage (the
% "!N" white mix; 0 = never tinted), and its rule darkening ("!M!black") — whose
% defaults reproduce the v1.1 look exactly.  Two global toggles drop the left
% rule or the background tint across all families.  \texlibtheoremsetup{...}
% changes any of these and rebuilds the styles, so it works in a preamble or
% mid-document:
%
%   \texlibtheoremsetup{rule=false}                 % no left rules anywhere
%   \texlibtheoremsetup{tint=false}                 % no background tints
%   \texlibtheoremsetup{theorem-color=purple,       % recolour individual
%                       definition-color=teal}      %   families (rule + tint)
%
% Implementation note: the styles are rebuilt with LITERAL colour values baked
% in (via \edef), and the left rule's `borderline west` is omitted entirely
% when rule=false — so xcolor/tcolorbox never see a conditional and a disabled
% rule leaves no degenerate mark.  The rule WIDTH stays the live
% \texlibrulewidth, preserving the single-source-of-truth tuning above.

\newif\iftexlib@thm@rule  \texlib@thm@ruletrue
\newif\iftexlib@thm@tint  \texlib@thm@tinttrue

% \texlib@thm@param{family}{hue}{tint-pct}{rule-mix}
\newcommand{\texlib@thm@param}[4]{%
	\@namedef{texlib@thm@hue@#1}{#2}%
	\@namedef{texlib@thm@pct@#1}{#3}%
	\@namedef{texlib@thm@mix@#1}{#4}%
}
\texlib@thm@param{theorem}    {red}    {2}{60}
\texlib@thm@param{proposition}{violet} {2}{60}
\texlib@thm@param{definition} {blue}   {2}{60}
\texlib@thm@param{procedure}  {teal}   {2}{60}
\texlib@thm@param{example}    {black}  {0}{60}   % "quiet" family: never tinted
\texlib@thm@param{question}   {orange} {3}{60}
\texlib@thm@param{note}       {gray}   {4}{50}

% Rebuild one family's tcolorbox style from its current parameters + the global
% toggles, reducing colback/border colour to literals before \tcbset sees them.
\newcommand{\texlib@thm@build}[1]{%
	\edef\texlib@thm@bg{%
		\iftexlib@thm@tint
			\ifnum\@nameuse{texlib@thm@pct@#1}=0 white%
			\else \@nameuse{texlib@thm@hue@#1}!\@nameuse{texlib@thm@pct@#1}!white\fi
		\else white\fi}%
	\edef\texlib@thm@rc{\@nameuse{texlib@thm@hue@#1}!\@nameuse{texlib@thm@mix@#1}!black}%
	\edef\texlib@thm@do{%
		\noexpand\tcbset{texlib#1/.style={texlibbase, colback=\texlib@thm@bg
			\iftexlib@thm@rule
				,borderline west={\noexpand\texlibrulewidth}{0pt}{\texlib@thm@rc}%
			\fi}}}%
	\texlib@thm@do
}
% Rebuild every family.  Called at load (with the defaults above) and by
% \texlibtheoremsetup after a settings change.
\newcommand{\texlibtheoremrebuild}{%
	\texlib@thm@build{theorem}\texlib@thm@build{proposition}%
	\texlib@thm@build{definition}\texlib@thm@build{procedure}%
	\texlib@thm@build{example}\texlib@thm@build{question}\texlib@thm@build{note}%
}
\texlibtheoremrebuild

% Public key interface.
\pgfqkeys{/texlib/thm}{%
	rule/.is choice, rule/true/.code={\texlib@thm@ruletrue}, rule/false/.code={\texlib@thm@rulefalse},
	tint/.is choice, tint/true/.code={\texlib@thm@tinttrue}, tint/false/.code={\texlib@thm@tintfalse},
	theorem-color/.code     ={\@namedef{texlib@thm@hue@theorem}{#1}},
	proposition-color/.code ={\@namedef{texlib@thm@hue@proposition}{#1}},
	definition-color/.code  ={\@namedef{texlib@thm@hue@definition}{#1}},
	procedure-color/.code   ={\@namedef{texlib@thm@hue@procedure}{#1}},
	example-color/.code     ={\@namedef{texlib@thm@hue@example}{#1}},
	question-color/.code    ={\@namedef{texlib@thm@hue@question}{#1}},
	note-color/.code        ={\@namedef{texlib@thm@hue@note}{#1}},
}
% \texlibtheoremsetup{key=value, ...} — update the theorem look. Keys:
%   rule = true|false          left rule on/off (all families)
%   tint = true|false          background tint on/off (all families)
%   <family>-color = <hue>     recolour one family (drives its rule + tint);
%                              <family> in theorem/proposition/definition/
%                              procedure/example/question/note.
\newcommand{\texlibtheoremsetup}[1]{%
	\pgfqkeys{/texlib/thm}{#1}%
	\texlibtheoremrebuild
}

\endinput
