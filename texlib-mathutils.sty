% texlib-mathutils.sty
% Shared math macros for the TeXLib teaching library.
%
% Loaded directly by classes that don't pull in basic-utilities.sty
% (autoexam, quiz); loaded transitively via basic-utilities for classes
% that want the full utility kit (didactic, pset, report-card).
%
% Conventions chosen during the May 2026 consolidation pass:
%
%   - Delimiter macros use \left ... \right (auto-sizing). The earlier
%     \mathopen{}...\mathclose{} wrappers in basic-utilities had typos
%     (\mathopen{} at BOTH ends instead of \mathopen{}/\mathclose{}) and
%     produced subtly wrong spacing for \abs, \lrcb, and \lrsb. Plain
%     \left\right is simpler, correct, and matches the didactic/pset
%     definitions that were already in use.
%
%   - All macros use \providecommand / \ProvideDocumentCommand so a
%     downstream document can \renewcommand them without erroring.
%
%   - \deriv uses the simpler didactic signature: the function argument
%     is mandatory, so \IfValueTF was a no-op in the older basic-utilities
%     version.
%
%   - \todo defaults to bold red "TODO" (the 3-of-5 majority across the
%     pre-consolidation copies). autoexam's plain-red \todo and
%     basic-utilities' lowercase "todo." are both retired.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{texlib-mathutils}[2026/05/13 v1.0 TeXLib shared math utilities]

\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{mathtools}
\RequirePackage{xcolor}
\RequirePackage{xparse}
\RequirePackage{mathrsfs}  % provides \mathscr, used by \mscr below.
                           % Previously \mscr was defined in several classes
                           % but mathrsfs was never loaded, so \mscr errored
                           % the moment it was used in a document body.

% --- Accessible math alt-text (MathML intent) -------------------------------
% \TeXLibMathIntent{intent}{math}: attach a MathML "intent" so a screen reader
% reads <math> as the given alt-text during an ACCESSIBLE build (the tagged
% PDF/UA variant, texlib-build.sty -> \ifTeXLibAccessible); a no-op in every
% normal build, so documents behave identically when not tagging. Built on
% \MathMLintent (LaTeX tagging project), mirroring UNR Hurtado's approach.
%
% IMPORTANT -- single node only. luamml can attach an intent only to a SINGLE
% math node (one symbol, or one \sin^{-1}-style super/subscript). A multi-node
% or delimited expression (anything with \left..\right, plain \lvert x\rvert,
% f(x), ...) makes luamml warn "Multiple math nodes" and DROP the intent -- the
% build still succeeds, the alt-text is just ignored. So use it on ambiguous
% single glyphs / scripted operators, e.g. inverse trig (the notation reads as
% "sine to the negative one power" by default):
%
%     \newcommand{\sininv}{\TeXLibMathIntent{inverse-sine}{\sin^{-1}}}
%     \newcommand{\Jac}{\TeXLibMathIntent{Jacobian-matrix}{\mathbf{J}}}
%
% The auto-sizing delimiters below are deliberately NOT wrapped: they are
% multi-node, so an intent would be silently discarded.
%
% Both branches are defined at load time and \TeXLibMathIntent is \let to one of
% them; \AtBeginDocument (after texlib-build has run and any source-level
% \accessible / compile-time flag is settled) swaps to the active branch when
% both the accessible flag and \MathMLintent are present. Defining the two-arg
% branches up front -- rather than \renewcommand-ing inside the hook -- avoids
% the # parameter-doubling that a parametered \def built inside \AtBeginDocument
% would suffer.
\newcommand{\texlib@mathintent@off}[2]{#2}
\newcommand{\texlib@mathintent@on}[2]{\MathMLintent{#1}{#2}}
\newcommand{\TeXLibMathIntent}{\texlib@mathintent@off}
% \ifTeXLibAccessible belongs to texlib-build.sty, which the CLASSES load -- but
% this package is pulled in earlier (via texlib-corepkg) and may be used without
% it. Guarantee the conditional exists rather than testing for it inline:
% wrapping a POSSIBLY-UNDEFINED conditional in a guard is what produced the
% "Extra \fi" at \begin{document}. When TeX skips a false branch it counts nested
% conditionals BY MEANING; an undefined \ifTeXLibAccessible is not counted, yet
% the source still carries a matching \fi, so the skipper closes the outer
% conditional one \fi early and the last \fi is orphaned. With the flag always
% defined, the conditional below is symmetric under both execution and skipping.
% (texlib-build.sty re-runs \newif later, which resets and then sets it from
% \TeXLibAccessibleMode -- it loads after this package, so that ordering is fine.)
\ifcsname ifTeXLibAccessible\endcsname\else \newif\ifTeXLibAccessible \fi
\AtBeginDocument{%
  \ifTeXLibAccessible
    \ifcsname MathMLintent\endcsname
      \let\TeXLibMathIntent\texlib@mathintent@on
    \fi
  \fi
}

% --- Math-font shortcuts ----------------------------------------------------
\providecommand{\mbb}[1]{\mathbb{#1}}
\providecommand{\mrm}[1]{\mathrm{#1}}
\providecommand{\mcal}[1]{\mathcal{#1}}
\providecommand{\msf}[1]{\mathsf{#1}}
\providecommand{\mf}[1]{\mathfrak{#1}}
\providecommand{\mscr}[1]{\mathscr{#1}}

% --- Auto-sizing delimiters -------------------------------------------------
\providecommand{\abs}[1]{\left\lvert #1 \right\rvert}
\providecommand{\lrp}[1]{\left( #1 \right)}
\providecommand{\lrb}[1]{\left[ #1 \right]}
\providecommand{\lrsb}[1]{\left[ #1 \right]}   % alias of \lrb (kept for back-compat)
\providecommand{\lrcb}[1]{\left\{ #1 \right\}}

